# Qdrant Configuration Environment Variables
# Copy this file to .env and update with your values

# API Security - IMPORTANT: Set these in production!
QDRANT_API_KEY=change-this-to-a-strong-random-key
QDRANT_READ_ONLY_API_KEY=change-this-to-a-different-strong-key

# Port Configuration
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Resource Limits (adjust based on your server capacity)
QDRANT_CPU_LIMIT=4
QDRANT_MEMORY_LIMIT=8G
QDRANT_CPU_RESERVATION=2
QDRANT_MEMORY_RESERVATION=4G

# Log Level (DEBUG, INFO, WARN, ERROR)
QDRANT_LOG_LEVEL=INFO

# Telemetry
QDRANT_TELEMETRY_DISABLED=false

# CORS (set to false if not needed)
QDRANT_ENABLE_CORS=true
