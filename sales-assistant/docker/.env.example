# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Evolution API ─────────────────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=sales-agent

# ── Nuvemshop ─────────────────────────────────────────────────────────────────
# Set NUVEMSHOP_MOCK=true to use mock/catalog.json instead of the real API
NUVEMSHOP_MOCK=false
NUVEMSHOP_STORE_ID=1234567
NUVEMSHOP_ACCESS_TOKEN=your-nuvemshop-access-token

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=salesagent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sales_agent
DATABASE_URL=postgresql+asyncpg://salesagent:changeme@postgres:5432/sales_agent

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Kestra ────────────────────────────────────────────────────────────────────
KESTRA_URL=http://kestra:8080

# ── Business config ───────────────────────────────────────────────────────────
# Owner's WhatsApp number in E.164 format (without @s.whatsapp.net)
OWNER_PHONE_NUMBER=5511999999999

# ── Performance ───────────────────────────────────────────────────────────────
MAX_DISCOVERY_TURNS=3
RESPONSE_TIMEOUT_SECONDS=30
